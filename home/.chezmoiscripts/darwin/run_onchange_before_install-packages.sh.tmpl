{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set -eufo pipefail

{{ $brews := list
     "bat"
     "bitwarden-cli"
     "bottom"
     "curlie"
     "duf"
     "dust"
     "eza"
     "fd"
     "fzf"
     "gh"
     "git"
     "git-delta"
     "git-lfs"
     "bash"
     "coreutils"
     "diffutils"
     "findutils"
     "gawk"
     "gnu-sed"
     "gnu-tar"
     "grep"
     "gzip"
     "unzip"
     "gnu-units"
     "gnupg"
     "gping"
     "jq"
     "pastel"
     "pinentry-mac"
     "ripgrep"
     "mise"
     "antidote"
     "shellcheck"
     "tmux"
     "vivid"
     "wget"
     "xsv"
     "zoxide"
     "zstd" -}}
{{ $casks := list
     "alt-tab"
     "hammerspoon"
     "iterm2"
     "karabiner-elements"
     "visual-studio-code" -}}

brew bundle --file=/dev/stdin <<EOF
{{ range ($brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
{{ range ($casks | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end -}}
EOF
{{- end }}
