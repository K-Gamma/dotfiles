Include ~/.ssh/config.d/*.conf

# https://man.openbsd.org/ssh_config
Host *
    # Automatically add keys to the running ssh-agent
    AddKeysToAgent yes
    # Forward the authentication agent connection to the remote machine
    ForwardAgent yes
    # Forward X11 connections over the secure channel
    ForwardX11 yes
    ForwardX11Trusted yes
    # Automatically add new host keys to known_hosts
    StrictHostKeyChecking no
    # Disable password authentication
    PasswordAuthentication no
    # Disable keyboard-interactive authentication
    KbdInteractiveAuthentication no
    # Send keepalive message every 60 seconds
    ServerAliveInterval 60
    # Enable legacy ssh-rsa (SHA-1) algorithm, disabled by default since OpenSSH 8.8
    HostkeyAlgorithms +ssh-rsa
