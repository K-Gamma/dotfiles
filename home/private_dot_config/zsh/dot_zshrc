function extract() {
  if [[ $# -eq 0 ]]; then
    print -P "%F{red}usage:%f extract <file> ..." >&2
    return 1
  fi
  local file
  for file in "$@"; do
    if [[ ! -f "$file" ]]; then
      print -P "%F{red}not found:%f $file" >&2
      continue
    fi
    case $file in
      *.tar.gz|*.tgz)     tar xzvf "$file";;
      *.tar.xz)           tar Jxvf "$file";;
      *.tar.bz2|*.tbz)    tar xjvf "$file";;
      *.tar.zst)           tar --zstd -xvf "$file";;
      *.tar.Z)             tar zxvf "$file";;
      *.tar)               tar xvf "$file";;
      *.gz)                gzip -d "$file";;
      *.bz2)               bzip2 -dc "$file";;
      *.zst)               zstd -d "$file";;
      *.xz)                xz -d "$file";;
      *.Z)                 uncompress "$file";;
      *.zip)               unzip "$file";;
      *.lzh)               lha e "$file";;
      *.7z)                7z x "$file";;
      *.rar)               unrar x "$file";;
      *.arj)               unarj "$file";;
      *)
        print -P "%F{red}unknown format:%f $file" >&2
        ;;
    esac
  done
}
alias -s {gz,tgz,zip,lzh,bz2,tbz,Z,tar,arj,xz,zst,7z,rar}=extract

