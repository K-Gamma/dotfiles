# ++ Completion Settings {{{
# Cache compinit dump file for 1 day (reset: run-compinit --force)
zstyle ':plugin:ez-compinit' 'use-cache' 'yes'

# Select completion candidates via menu selection.
# select=2: start menu selection when 2+ candidates, otherwise complete immediately.
zstyle ':completion:*' menu select=2

# Case-insensitive completion (lowercase matches uppercase).
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# Keep prefix containing tilde or parameter expansion (e.g. ~/f -> ~/foo, not /home/usr/foo).
zstyle ':completion:*' keep-prefix

### Completers:
### _oldlist: Reuse the previous completion result.
### _complete: Generate completions in a context-sensitive manner.
### _match: Complete using pattern matching without expanding globs.
### _history: Complete words from the shell's command history.
### _ignored: Reinstate matches excluded by ignored-patterns.
### _approximate: Allow completions to undergo corrections.
### _prefix: Complete with the suffix (everything after cursor) ignored.
zstyle ':completion:*' completer _complete _ignored _prefix _approximate

# Colorize completion candidates using LS_COLORS.
if [[ -n "${LS_COLORS}" ]]; then
  zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
fi

# Ignore parent and current working directory from cd completion.
zstyle ':completion:*:cd:*' ignore-parents parent pwd

# Exclude object files and intermediate files from completion.
zstyle ':completion:*:*files' ignored-patterns '*?.o' '*?~' '*\#'

# Search paths for command completion under sudo.
zstyle ':completion:*:sudo:*' command-path \
  "/usr/local/sbin" \
  "/usr/local/bin"  \
  "/usr/sbin"       \
  "/usr/bin"        \
  "/sbin"           \
  "/bin"

# Enable completion caching.
zstyle ':completion:*' use-cache true
zstyle ':completion:*' cache-path "${XDG_CACHE_HOME}/zsh/zcompcache"

# Disable verbose completion listings.
zstyle ':completion:*' verbose no

# Format string displayed above completion matches.
zstyle ':completion:*:descriptions' format '%BCompleting%b %U%d%u'
zstyle ':completion:*' group-name ''

# Separator between completion string and description.
zstyle ':completion:*' list-separator '-->'

# Show warning when no matches found.
zstyle ':completion:*:warnings' format '%F{red}-- no matches found --%f'

# Treat // as / instead of /*/
zstyle ':completion:*' squeeze-slashes true

# Allow 1 error per 3 characters for approximate completion.
zstyle ':completion:*:approximate:*' max-errors 1 numeric

# Don't complete the same argument twice for rm, kill, diff.
zstyle ':completion:*:(rm|kill|diff):*' ignore-line other

# Colorize and force menu for kill completion.
zstyle ':completion:*:*:*:*:processes' command 'ps -u $LOGNAME -o pid,user,command -w'
zstyle ':completion:*:*:kill:*:processes' list-colors '=(#b) #([0-9]#) ([0-9a-z-]#)*=01;36=0=01'
zstyle ':completion:*:*:kill:*' menu yes select
zstyle ':completion:*:*:kill:*' force-list always

# Hide internal functions (_*) and precmd/preexec from command completion.
zstyle ':completion:*:functions' ignored-patterns '(_*|pre(cmd|exec))'
# ++ }}}
